{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "PCM Recon",
  "version": "2.0.0",
  "identifier": "com.ngen.pcm-recon",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "PCM Recon",
        "width": 1700,
        "height": 980,
        "minWidth": 1300,
        "minHeight": 800,
        "resizable": true,
        "fullscreen": false,
        "decorations": true,
        "transparent": false,
        "center": true
      }
    ],
    "security": { "csp": null }
  },
  "plugins": {
    "dialog": {}
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "wix": {},
      "nsis": {}
    },
    "publisher": "nGen"
  }
}
